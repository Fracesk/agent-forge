// ============================================================
// AgentForge — AI Agent Collaboration Platform
// Prisma Schema (PostgreSQL + pgvector)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------
// Auth.js v5 Models
// -----------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  authenticators Authenticator[]

  passwordHash  String?

  bio           String?
  preferences   Json?     @default("{}")

  agents        Agent[]
  conversations Conversation[]
  projects      Project[]
  tasks         Task[]
  tasksAssigned Task[]        @relation("TaskAssignee")
  apiKeys       ApiKey[]
  memories      AgentMemory[]
  ownedCollaborations AgentCollaboration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  id                   String  @id @default(cuid())
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------
// API Keys
// -----------------------------------------------------------

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// -----------------------------------------------------------
// Tool Registry
// -----------------------------------------------------------

model Tool {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String @db.Text
  category    String
  schema      Json
  enabled     Boolean  @default(true)
  config      Json?
  builtIn     Boolean  @default(true)

  agents AgentTool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------
// Agent
// -----------------------------------------------------------

model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String? @db.Text
  avatarUrl     String?
  systemPrompt  String @db.Text
  model         String   @default("qwen:qwen3.7-max")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(4096)
  status        String   @default("idle")

  personality   Json?
  instructions  String? @db.Text
  role          String?
  maxConcurrency Int     @default(1)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic      Boolean  @default(false)

  tools         AgentTool[]
  conversations Conversation[]
  memories      AgentMemory[]
  tasks         Task[]
  collaborations AgentCollaborationAgent[]
  messages      Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AgentTool {
  agentId String
  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolId  String
  tool    Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  config  Json?

  @@id([agentId, toolId])
  @@index([toolId])
}

// -----------------------------------------------------------
// Conversation
// -----------------------------------------------------------

model Conversation {
  id        String   @id @default(cuid())
  title     String?  @default("New Conversation")
  summary   String? @db.Text
  type      String   @default("chat")
  metadata  Json?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  agents    Agent[]
  messages  Message[]
  collaboration AgentCollaboration?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([updatedAt])
}

// -----------------------------------------------------------
// Message
// -----------------------------------------------------------

model Message {
  id        String   @id @default(cuid())
  role      String
  content   String @db.Text

  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentName String?

  toolCalls   Json?
  toolCallId  String?
  latency     Int?
  tokensIn    Int?     @default(0)
  tokensOut   Int?     @default(0)
  model       String?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([agentId])
  @@index([createdAt])
}

// -----------------------------------------------------------
// Agent Memory (Vector Store — pgvector when on PostgreSQL)
// -----------------------------------------------------------

model AgentMemory {
  id        String   @id @default(cuid())
  type      String   @default("episodic")
  content   String @db.Text
  summary   String?
  metadata  Json?

  // TODO: Change to Unsupported("vector(1536)?") when pgvector is available (Phase 3)
  embedding String?
  importance Float   @default(0.5)

  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  lastAccessedAt DateTime @default(now())

  @@index([agentId, type])
  @@index([agentId, importance])
  @@index([userId])
}

// -----------------------------------------------------------
// Project
// -----------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  name        String
  description String? @db.Text
  status      String   @default("active")
  color       String?
  deadline    DateTime?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversations Conversation[]
  tasks         Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// -----------------------------------------------------------
// Task
// -----------------------------------------------------------

model Task {
  id          String   @id @default(cuid())
  title       String
  description String? @db.Text
  status      String   @default("pending")
  priority    String   @default("medium")
  progress    Int      @default(0)

  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  collaborationId String?
  collaboration   AgentCollaboration? @relation(fields: [collaborationId], references: [id], onDelete: SetNull)

  dependsOn   TaskDependency[] @relation("TaskDependencyDependent")
  dependedBy  TaskDependency[] @relation("TaskDependencyDependsOn")

  output      Json?
  error       String? @db.Text
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
}

model TaskDependency {
  id          String @id @default(cuid())
  taskId      String
  dependsOnId String
  type        String @default("blocks")

  task      Task @relation("TaskDependencyDependent", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependencyDependsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

// -----------------------------------------------------------
// Agent Collaboration (Swarm)
// -----------------------------------------------------------

model AgentCollaboration {
  id          String   @id @default(cuid())
  name        String
  description String? @db.Text
  status      String   @default("active")
  strategy    String   @default("sequential")
  maxRounds   Int      @default(5)
  config      Json?

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  conversationId String?   @unique
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  agents      AgentCollaborationAgent[]
  tasks       Task[]

  result      Json?
  error       String? @db.Text
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AgentCollaborationAgent {
  id              String @id @default(cuid())
  collaborationId String
  collaboration   AgentCollaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role            String?
  order           Int     @default(0)
  status          String  @default("pending")

  input           String? @db.Text
  output          String? @db.Text

  @@unique([collaborationId, agentId])
  @@index([collaborationId])
}
